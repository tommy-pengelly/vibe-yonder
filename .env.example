# Supabase project credentials. Leave both blank to run in guest-only mode
# (everything works locally; "Save to account" prompts that you haven't configured auth).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Contact string baked into the User-Agent sent to Nominatim. Their policy
# requires an identifying UA. Change before any real traffic.
NOMINATIM_CONTACT=tom.peng95@gmail.com

# Geocoder: "photon" (default, proximity-biased autocomplete) or "nominatim".
# GEOCODER=photon

# Feature flags. Discovery (the on-walk constellation + "around you" suggestions
# + /api/nearby Overpass fetches) is OFF by default while the taste is reworked.
# Set to "on" to bring it back.
# NEXT_PUBLIC_DISCOVERY=on
